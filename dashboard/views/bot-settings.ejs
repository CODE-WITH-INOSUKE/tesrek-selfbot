<!-- dashboard/views/bot-settings.ejs - NEW PAGE -->
<%- include('partials/header') %>
<%- include('partials/sidebar', { currentPage: 'bot-settings', allowedUsers: allowedUsers }) %>

<div>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="font-size: 36px; font-weight: 800;">
            <span class="gradient-text">Bot Settings</span>
        </h1>
        <div class="glass-morphism" style="padding: 10px 20px; border-radius: 30px;">
            <i class="fas fa-robot" style="color: #00ff88; margin-right: 10px;"></i>
            Discord Bot Configuration
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 25px;">
        <!-- Main Bot Settings -->
        <div class="modern-card">
            <h3 style="font-size: 20px; margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-robot" style="color: #00ff88;"></i>
                Discord Bot Configuration
            </h3>
            
            <div style="margin-bottom: 25px; padding: 15px; background: rgba(0,255,136,0.1); border-radius: 12px; display: flex; align-items: center; gap: 15px;">
                <img src="<%= botUser ? `https://cdn.discordapp.com/avatars/${botUser.id}/${botUser.avatar}.png?size=256` : 'https://via.placeholder.com/50' %>" 
                     style="width: 50px; height: 50px; border-radius: 50%; border: 2px solid #00ff88;">
                <div>
                    <p style="font-weight: 700;"><%= botUser ? botUser.tag : 'Bot not connected' %></p>
                    <p style="color: rgba(255,255,255,0.6); font-size: 12px;">ID: <%= botUser ? botUser.id : 'N/A' %></p>
                </div>
            </div>
            
            <form method="POST" action="/bot-settings">
                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 15px; color: rgba(255,255,255,0.8); font-weight: 500;">
                        <i class="fas fa-eye-slash" style="color: #00ff88; margin-right: 8px;"></i>
                        Ephemeral Messages
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                        <input type="checkbox" name="slashEphemeral" <%= config.slashEphemeral ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #00ff88;">
                        <span>Hide responses from other users (ephemeral)</span>
                    </label>
                    <p style="color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 5px;">
                        <i class="fas fa-info-circle"></i> Only the command user can see bot responses
                    </p>
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 15px; color: rgba(255,255,255,0.8); font-weight: 500;">
                        <i class="fas fa-comment" style="color: #00ff88; margin-right: 8px;"></i>
                        Selfbot Responses
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                        <input type="checkbox" name="selfbotResponses" <%= config.selfbotResponses ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #00ff88;">
                        <span>Selfbot sends confirmation messages</span>
                    </label>
                    <p style="color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 5px;">
                        <i class="fas fa-info-circle"></i> Selfbot will send a message when commands are used
                    </p>
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 10px; color: rgba(255,255,255,0.8); font-weight: 500;">
                        <i class="fas fa-palette" style="color: #00ff88; margin-right: 8px;"></i>
                        Embed Style
                    </label>
                    <select name="slashEmbedStyle" class="futuristic-input" style="max-width: 300px;">
                        <option value="default" style="background: #1a1a1a;" <%= config.slashEmbedStyle === 'default' ? 'selected' : '' %>>Default</option>
                        <option value="minimal" style="background: #1a1a1a;" <%= config.slashEmbedStyle === 'minimal' ? 'selected' : '' %>>Minimal</option>
                        <option value="detailed" style="background: #1a1a1a;" <%= config.slashEmbedStyle === 'detailed' ? 'selected' : '' %>>Detailed</option>
                        <option value="none" style="background: #1a1a1a;" <%= config.slashEmbedStyle === 'none' ? 'selected' : '' %>>Plain Text</option>
                    </select>
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 10px; color: rgba(255,255,255,0.8); font-weight: 500;">
                        <i class="fas fa-circle" style="color: #00ff88; margin-right: 8px;"></i>
                        Bot Status
                    </label>
                    <select name="botStatus" class="futuristic-input" style="max-width: 300px;">
                        <option value="online" style="background: #1a1a1a;" <%= config.botStatus === 'online' ? 'selected' : '' %>>Online</option>
                        <option value="idle" style="background: #1a1a1a;" <%= config.botStatus === 'idle' ? 'selected' : '' %>>Idle</option>
                        <option value="dnd" style="background: #1a1a1a;" <%= config.botStatus === 'dnd' ? 'selected' : '' %>>Do Not Disturb</option>
                    </select>
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 10px; color: rgba(255,255,255,0.8); font-weight: 500;">
                        <i class="fas fa-gamepad" style="color: #00ff88; margin-right: 8px;"></i>
                        Bot Activity
                    </label>
                    <input type="text" name="botActivity" class="futuristic-input" value="<%= config.botActivity || '' %>" placeholder="e.g., with slash commands">
                </div>

                <button type="submit" class="neon-btn" style="padding: 15px 40px; font-size: 16px;">
                    <i class="fas fa-save"></i> Save Bot Settings
                </button>
            </form>
        </div>

        <!-- Info Panel -->
        <div class="modern-card">
            <h3 style="font-size: 20px; margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-info-circle" style="color: #00ff88;"></i>
                Bot Information
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div style="padding: 15px; background: rgba(255,255,255,0.05); border-radius: 12px;">
                    <p style="color: #00ff88; margin-bottom: 5px;">Slash Commands</p>
                    <p style="font-size: 24px; font-weight: 700;"><%= bot.slashCommands.size %></p>
                    <p style="color: rgba(255,255,255,0.4); font-size: 12px;">registered globally</p>
                </div>
                
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>