<!-- dashboard/views/rpc.ejs - Complete RPC Configuration Page -->
<%- include('partials/header') %>
<%- include('partials/sidebar', { currentPage: 'rpc', allowedUsers: allowedUsers }) %>

<style>
    .rpc-container {
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .rpc-preview {
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        padding: 25px;
        border: 2px solid rgba(0,255,136,0.2);
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }
    
    .rpc-preview::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #00ff88, #00ccff, #00ff88);
        background-size: 200% 100%;
        animation: gradientMove 3s linear infinite;
    }
    
    @keyframes gradientMove {
        0% { background-position: 0% 0%; }
        100% { background-position: 200% 0%; }
    }
    
    .preview-card {
        display: flex;
        align-items: center;
        gap: 20px;
        background: rgba(0,0,0,0.3);
        border-radius: 15px;
        padding: 20px;
        border: 1px solid rgba(255,255,255,0.1);
    }
    
    .preview-assets {
        position: relative;
        width: 100px;
        height: 100px;
    }
    
    .preview-large {
        width: 100px;
        height: 100px;
        border-radius: 15px;
        background: linear-gradient(135deg, #00ff88, #00ccff);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: #000;
    }
    
    .preview-small {
        position: absolute;
        bottom: -5px;
        right: -5px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00ff88, #00ccff);
        border: 3px solid #1a1a2e;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }
    
    .preview-info {
        flex: 1;
    }
    
    .preview-details {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 5px;
        color: #00ff88;
    }
    
    .preview-state {
        font-size: 14px;
        color: rgba(255,255,255,0.7);
        margin-bottom: 10px;
    }
    
    .preview-timestamp {
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    .preview-buttons {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }
    
    .preview-button {
        padding: 5px 15px;
        background: rgba(0,255,136,0.1);
        border: 1px solid #00ff88;
        border-radius: 20px;
        color: #00ff88;
        font-size: 12px;
        cursor: default;
    }
    
    .preview-party {
        display: inline-block;
        padding: 3px 10px;
        background: rgba(255,255,255,0.05);
        border-radius: 12px;
        font-size: 12px;
        margin-top: 5px;
    }
    
    .section-title {
        font-size: 18px;
        margin: 25px 0 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #00ff88;
    }
    
    .section-title i {
        font-size: 20px;
    }
    
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }
    
    .setting-item {
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 15px;
        border: 1px solid rgba(0,255,136,0.1);
    }
    
    .setting-label {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        color: rgba(255,255,255,0.8);
        font-weight: 500;
    }
    
    .setting-label i {
        color: #00ff88;
        width: 20px;
    }
    
    .setting-help {
        font-size: 11px;
        color: rgba(255,255,255,0.4);
        margin-top: 5px;
    }
    
    .image-preview {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        background: linear-gradient(135deg, #00ff88, #00ccff);
        margin-top: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 30px;
    }
    
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    
    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255,255,255,0.1);
        transition: .3s;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.2);
    }
    
    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 24px;
        width: 24px;
        left: 3px;
        bottom: 2px;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }
    
    input:checked + .toggle-slider {
        background-color: #00ff88;
    }
    
    input:checked + .toggle-slider:before {
        transform: translateX(29px);
    }
    
    .button-pair {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 15px;
        padding: 15px;
        background: rgba(255,255,255,0.02);
        border-radius: 10px;
    }
    
    .party-slider {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .party-slider input {
        width: 80px;
    }
    
    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        flex-wrap: wrap;
    }
    
    .action-btn {
        padding: 12px 25px;
        border-radius: 30px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        border: none;
    }
    
    .save-btn {
        background: #00ff88;
        color: #000;
    }
    
    .save-btn:hover {
        box-shadow: 0 0 20px #00ff88;
        transform: translateY(-2px);
    }
    
    .test-btn {
        background: transparent;
        color: #00ff88;
        border: 2px solid #00ff88;
    }
    
    .test-btn:hover {
        background: #00ff88;
        color: #000;
    }
    
    .clear-btn {
        background: transparent;
        color: #ff6b6b;
        border: 2px solid #ff6b6b;
    }
    
    .clear-btn:hover {
        background: #ff6b6b;
        color: #000;
    }
    
    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin-left: 10px;
    }
    
    .status-active {
        background: rgba(0,255,136,0.2);
        color: #00ff88;
        border: 1px solid #00ff88;
    }
    
    .status-inactive {
        background: rgba(255,107,107,0.2);
        color: #ff6b6b;
        border: 1px solid #ff6b6b;
    }
</style>

<div class="rpc-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="font-size: 36px; font-weight: 800;">
            <span class="gradient-text">Rich Presence</span>
        </h1>
        <div class="glass-morphism" style="padding: 10px 20px; border-radius: 30px; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-discord" style="color: #00ff88;"></i>
            <span>Discord RPC</span>
            <span id="rpcStatus" class="status-badge <%= rpcConfig.enabled ? 'status-active' : 'status-inactive' %>">
                <%= rpcConfig.enabled ? 'ACTIVE' : 'INACTIVE' %>
            </span>
        </div>
    </div>

    <!-- Live Preview -->
    <div class="rpc-preview">
        <h3 style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-eye" style="color: #00ff88;"></i>
            Live Preview
        </h3>
        
        <div class="preview-card">
            <div class="preview-assets">
                <div class="preview-large" id="previewLargeIcon">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="preview-small" id="previewSmallIcon">
                    <i class="fas fa-circle"></i>
                </div>
            </div>
            <div class="preview-info">
                <div class="preview-details" id="previewDetails">Playing on SelfBot</div>
                <div class="preview-state" id="previewState">Dashboard Connected</div>
                <div class="preview-timestamp" id="previewTimestamp">
                    <i class="far fa-clock"></i>
                    <span>elapsed 00:05</span>
                </div>
                <div class="preview-party" id="previewParty" style="display: none;">
                    <i class="fas fa-users"></i>
                    <span>Party: 1/5</span>
                </div>
                <div class="preview-buttons" id="previewButtons"></div>
            </div>
        </div>
    </div>

    <form method="POST" action="/rpc/update" id="rpcForm">
        <!-- Enable/Disable Toggle -->
        <div class="setting-item" style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="setting-label">
                    <i class="fas fa-power-off"></i>
                    <span>Enable Rich Presence</span>
                </div>
                <div class="setting-help">Toggle RPC on/off for your selfbot</div>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" name="enabled" <%= rpcConfig.enabled ? 'checked' : '' %> onchange="updatePreview()">
                <span class="toggle-slider"></span>
            </label>
        </div>

        <!-- Basic Settings -->
        <div class="section-title">
            <i class="fas fa-info-circle"></i>
            Basic Information
        </div>

        <div class="settings-grid">
            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-heading"></i>
                    <span>Details (Line 1)</span>
                </div>
                <input type="text" name="details" class="futuristic-input" value="<%= rpcConfig.details %>" placeholder="Playing on SelfBot" oninput="updatePreview()">
                <div class="setting-help">Main text displayed on your profile</div>
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-subscript"></i>
                    <span>State (Line 2)</span>
                </div>
                <input type="text" name="state" class="futuristic-input" value="<%= rpcConfig.state %>" placeholder="Dashboard Connected" oninput="updatePreview()">
                <div class="setting-help">Secondary text below the main details</div>
            </div>
        </div>

        <!-- Assets Settings -->
        <div class="section-title">
            <i class="fas fa-images"></i>
            Assets & Images
        </div>

        <div class="settings-grid">
            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-image"></i>
                    <span>Large Image Key</span>
                </div>
                <input type="text" name="largeImageKey" class="futuristic-input" value="<%= rpcConfig.largeImageKey %>" placeholder="logo" oninput="updatePreview()">
                <div class="image-preview" id="largeImagePreview">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="setting-help">Asset key from Discord Developer Portal</div>
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-align-left"></i>
                    <span>Large Image Text</span>
                </div>
                <input type="text" name="largeImageText" class="futuristic-input" value="<%= rpcConfig.largeImageText %>" placeholder="SelfBot v3" oninput="updatePreview()">
                <div class="setting-help">Text shown when hovering over large image</div>
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-image"></i>
                    <span>Small Image Key</span>
                </div>
                <input type="text" name="smallImageKey" class="futuristic-input" value="<%= rpcConfig.smallImageKey %>" placeholder="online" oninput="updatePreview()">
                <div class="image-preview" id="smallImagePreview" style="width: 30px; height: 30px;">
                    <i class="fas fa-circle"></i>
                </div>
                <div class="setting-help">Small overlay image key</div>
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-align-left"></i>
                    <span>Small Image Text</span>
                </div>
                <input type="text" name="smallImageText" class="futuristic-input" value="<%= rpcConfig.smallImageText %>" placeholder="Online" oninput="updatePreview()">
                <div class="setting-help">Text shown when hovering over small image</div>
            </div>
        </div>

        <!-- Buttons -->
        <div class="section-title">
            <i class="fas fa-link"></i>
            Buttons (Max 2)
        </div>

        <div class="button-pair">
            <div>
                <div class="setting-label">
                    <i class="fas fa-tag"></i>
                    <span>Button 1 Label</span>
                </div>
                <input type="text" name="button1Label" class="futuristic-input" value="<%= rpcConfig.buttons && rpcConfig.buttons[0] ? rpcConfig.buttons[0].label : '' %>" placeholder="Join Server" oninput="updatePreview()">
            </div>
            <div>
                <div class="setting-label">
                    <i class="fas fa-link"></i>
                    <span>Button 1 URL</span>
                </div>
                <input type="url" name="button1Url" class="futuristic-input" value="<%= rpcConfig.buttons && rpcConfig.buttons[0] ? rpcConfig.buttons[0].url : '' %>" placeholder="https://discord.gg/..." oninput="updatePreview()">
            </div>
        </div>

        <div class="button-pair">
            <div>
                <div class="setting-label">
                    <i class="fas fa-tag"></i>
                    <span>Button 2 Label</span>
                </div>
                <input type="text" name="button2Label" class="futuristic-input" value="<%= rpcConfig.buttons && rpcConfig.buttons[1] ? rpcConfig.buttons[1].label : '' %>" placeholder="Dashboard" oninput="updatePreview()">
            </div>
            <div>
                <div class="setting-label">
                    <i class="fas fa-link"></i>
                    <span>Button 2 URL</span>
                </div>
                <input type="url" name="button2Url" class="futuristic-input" value="<%= rpcConfig.buttons && rpcConfig.buttons[1] ? rpcConfig.buttons[1].url : '' %>" placeholder="http://localhost:3000" oninput="updatePreview()">
            </div>
        </div>

        <!-- Party Settings -->
        <div class="section-title">
            <i class="fas fa-users"></i>
            Party Settings
        </div>

        <div class="settings-grid">
            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-user"></i>
                    <span>Party Size</span>
                </div>
                <div class="party-slider">
                    <input type="range" name="partySize" min="0" max="100" value="<%= rpcConfig.partySize %>" oninput="this.nextElementSibling.value = this.value; updatePreview()">
                    <input type="number" value="<%= rpcConfig.partySize %>" min="0" max="100" oninput="this.previousElementSibling.value = this.value; updatePreview()" style="width: 60px;">
                </div>
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-users"></i>
                    <span>Party Max</span>
                </div>
                <div class="party-slider">
                    <input type="range" name="partyMax" min="0" max="100" value="<%= rpcConfig.partyMax %>" oninput="this.nextElementSibling.value = this.value; updatePreview()">
                    <input type="number" value="<%= rpcConfig.partyMax %>" min="0" max="100" oninput="this.previousElementSibling.value = this.value; updatePreview()" style="width: 60px;">
                </div>
            </div>
        </div>

        <!-- Secrets -->
        <div class="section-title">
            <i class="fas fa-key"></i>
            Secrets (for join/spectate)
        </div>

        <div class="settings-grid">
            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Join Secret</span>
                </div>
                <input type="text" name="joinSecret" class="futuristic-input" value="<%= rpcConfig.joinSecret || '' %>" placeholder="join-secret-here">
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-gamepad"></i>
                    <span>Match Secret</span>
                </div>
                <input type="text" name="matchSecret" class="futuristic-input" value="<%= rpcConfig.matchSecret || '' %>" placeholder="match-secret-here">
            </div>

            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-eye"></i>
                    <span>Spectate Secret</span>
                </div>
                <input type="text" name="spectateSecret" class="futuristic-input" value="<%= rpcConfig.spectateSecret || '' %>" placeholder="spectate-secret-here">
            </div>
        </div>

        <!-- Timestamps -->
        <div class="section-title">
            <i class="fas fa-clock"></i>
            Timestamps
        </div>

        <div class="settings-grid">
            <div class="setting-item">
                <div class="setting-label">
                    <i class="fas fa-clock"></i>
                    <span>Timestamp Mode</span>
                </div>
                <select name="timestamps" class="futuristic-input" onchange="toggleTimestampFields(); updatePreview();">
                    <option value="none" <%= rpcConfig.timestamps === 'none' ? 'selected' : '' %>>No Timestamps</option>
                    <option value="start" <%= rpcConfig.timestamps === 'start' ? 'selected' : '' %>>Show Elapsed Time</option>
                    <option value="custom" <%= rpcConfig.timestamps === 'custom' ? 'selected' : '' %>>Custom Time Range</option>
                </select>
            </div>

            <div id="customTimestamps" style="display: <%= rpcConfig.timestamps === 'custom' ? 'block' : 'none' %>; grid-column: span 2;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <div class="setting-label">Start Time</div>
                        <input type="datetime-local" name="customStartTime" class="futuristic-input" value="<%= rpcConfig.startTime ? new Date(rpcConfig.startTime).toISOString().slice(0,16) : '' %>" onchange="updatePreview()">
                    </div>
                    <div>
                        <div class="setting-label">End Time</div>
                        <input type="datetime-local" name="customEndTime" class="futuristic-input" value="<%= rpcConfig.endTime ? new Date(rpcConfig.endTime).toISOString().slice(0,16) : '' %>" onchange="updatePreview()">
                    </div>
                </div>
            </div>
        </div>

        <!-- Instance -->
        <div class="setting-item" style="margin-top: 20px;">
            <label style="display: flex; align-items: center; gap: 15px; cursor: pointer;">
                <input type="checkbox" name="instance" <%= rpcConfig.instance ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #00ff88;">
                <div>
                    <div class="setting-label">Instance</div>
                    <div class="setting-help">Mark as an instance of a game (for join requests)</div>
                </div>
            </label>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
            <button type="submit" class="action-btn save-btn">
                <i class="fas fa-save"></i> Save Configuration
            </button>
            <button type="button" class="action-btn test-btn" onclick="testRPC()">
                <i class="fas fa-play"></i> Test RPC
            </button>
            <button type="button" class="action-btn clear-btn" onclick="clearRPC()">
                <i class="fas fa-trash"></i> Clear RPC
            </button>
        </div>
    </form>
</div>

<script>
// Update live preview
function updatePreview() {
    const form = document.getElementById('rpcForm');
    const enabled = form.querySelector('[name="enabled"]').checked;
    const details = form.querySelector('[name="details"]').value || 'Playing on SelfBot';
    const state = form.querySelector('[name="state"]').value || 'Dashboard Connected';
    const largeKey = form.querySelector('[name="largeImageKey"]').value;
    const largeText = form.querySelector('[name="largeImageText"]').value;
    const smallKey = form.querySelector('[name="smallImageKey"]').value;
    const smallText = form.querySelector('[name="smallImageText"]').value;
    const button1Label = form.querySelector('[name="button1Label"]').value;
    const button1Url = form.querySelector('[name="button1Url"]').value;
    const button2Label = form.querySelector('[name="button2Label"]').value;
    const button2Url = form.querySelector('[name="button2Url"]').value;
    const partySize = parseInt(form.querySelector('[name="partySize"]').value) || 0;
    const partyMax = parseInt(form.querySelector('[name="partyMax"]').value) || 0;
    const timestamps = form.querySelector('[name="timestamps"]').value;

    // Update status badge
    const statusBadge = document.getElementById('rpcStatus');
    statusBadge.className = `status-badge ${enabled ? 'status-active' : 'status-inactive'}`;
    statusBadge.textContent = enabled ? 'ACTIVE' : 'INACTIVE';

    // Update text
    document.getElementById('previewDetails').textContent = details;
    document.getElementById('previewState').textContent = state;

    // Update images
    const largeIcon = document.getElementById('previewLargeIcon');
    largeIcon.innerHTML = largeKey ? `<i class="fas fa-${largeKey}"></i>` : '<i class="fas fa-robot"></i>';
    
    const smallIcon = document.getElementById('previewSmallIcon');
    smallIcon.innerHTML = smallKey ? `<i class="fas fa-${smallKey}"></i>` : '<i class="fas fa-circle"></i>';

    // Update timestamp
    const timestampEl = document.getElementById('previewTimestamp');
    if (timestamps === 'start') {
        timestampEl.style.display = 'flex';
        timestampEl.querySelector('span').textContent = 'elapsed 00:05';
    } else if (timestamps === 'custom') {
        timestampEl.style.display = 'flex';
        timestampEl.querySelector('span').textContent = 'custom time range';
    } else {
        timestampEl.style.display = 'none';
    }

    // Update party
    const partyEl = document.getElementById('previewParty');
    if (partySize > 0 && partyMax > 0) {
        partyEl.style.display = 'inline-block';
        partyEl.querySelector('span').textContent = `Party: ${partySize}/${partyMax}`;
    } else {
        partyEl.style.display = 'none';
    }

    // Update buttons
    const buttonsEl = document.getElementById('previewButtons');
    buttonsEl.innerHTML = '';
    if (button1Label && button1Url) {
        buttonsEl.innerHTML += `<span class="preview-button">${button1Label}</span>`;
    }
    if (button2Label && button2Url) {
        buttonsEl.innerHTML += `<span class="preview-button">${button2Label}</span>`;
    }
}

// Toggle timestamp fields
function toggleTimestampFields() {
    const select = document.querySelector('[name="timestamps"]');
    const customDiv = document.getElementById('customTimestamps');
    customDiv.style.display = select.value === 'custom' ? 'block' : 'none';
    updatePreview();
}

// Test RPC
async function testRPC() {
    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';
    btn.disabled = true;

    try {
        const response = await fetch('/rpc/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (data.success) {
            showNotification('RPC test successful!', 'success');
        } else {
            showNotification('RPC test failed: ' + data.error, 'error');
        }
    } catch (error) {
        showNotification('Failed to test RPC', 'error');
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

// Clear RPC
async function clearRPC() {
    if (!confirm('Clear current Rich Presence?')) return;

    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Clearing...';
    btn.disabled = true;

    try {
        const response = await fetch('/rpc/clear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (data.success) {
            showNotification('RPC cleared!', 'success');
            // Reset form fields to default
            document.querySelector('[name="enabled"]').checked = false;
            document.querySelector('[name="details"]').value = 'Playing on SelfBot';
            document.querySelector('[name="state"]').value = 'Dashboard Connected';
            updatePreview();
        } else {
            showNotification('Failed to clear RPC', 'error');
        }
    } catch (error) {
        showNotification('Failed to clear RPC', 'error');
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

// Show notification
function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 15px 25px;
        background: ${type === 'success' ? 'rgba(0,255,136,0.2)' : 'rgba(255,107,107,0.2)'};
        border: 2px solid ${type === 'success' ? '#00ff88' : '#ff6b6b'};
        border-radius: 10px;
        color: ${type === 'success' ? '#00ff88' : '#ff6b6b'};
        z-index: 1001;
        backdrop-filter: blur(10px);
        font-weight: 500;
    `;
    notification.textContent = message;
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.remove();
    }, 3000);
}

// Initialize preview on load
document.addEventListener('DOMContentLoaded', () => {
    updatePreview();
    toggleTimestampFields();
});
</script>

