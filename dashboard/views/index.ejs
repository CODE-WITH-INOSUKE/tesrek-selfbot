<!-- dashboard/views/index.ejs -->
<%- include('partials/header') %>
<%- include('partials/sidebar', { currentPage: 'home' }) %>

<div>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="font-size: 36px; font-weight: 800;">
            <span class="gradient-text">Dashboard</span>
        </h1>
        <div class="glass-morphism" style="padding: 10px 20px; border-radius: 30px;">
            <i class="fas fa-calendar-alt" style="color: #00ff88; margin-right: 10px;"></i>
            <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </div>
    </div>

    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin-bottom: 40px;">
        <div class="modern-card" style="position: relative; overflow: hidden;">
            <div style="position: relative; z-index: 1;">
                <i class="fas fa-server" style="font-size: 40px; color: #00ff88; margin-bottom: 15px;"></i>
                <h3 style="font-size: 14px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px;">Guilds</h3>
                <p style="font-size: 48px; font-weight: 800; margin-top: 10px;"><%= guilds %></p>
            </div>
            <div style="position: absolute; bottom: -20px; right: -20px; font-size: 100px; color: rgba(255,255,255,0.03);">
                <i class="fas fa-server"></i>
            </div>
        </div>

        <div class="modern-card" style="position: relative; overflow: hidden;">
            <div style="position: relative; z-index: 1;">
                <i class="fas fa-users" style="font-size: 40px; color: #00ff88; margin-bottom: 15px;"></i>
                <h3 style="font-size: 14px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px;">Users</h3>
                <p style="font-size: 48px; font-weight: 800; margin-top: 10px;"><%= users %></p>
            </div>
            <div style="position: absolute; bottom: -20px; right: -20px; font-size: 100px; color: rgba(255,255,255,0.03);">
                <i class="fas fa-users"></i>
            </div>
        </div>

        <div class="modern-card" style="position: relative; overflow: hidden;">
            <div style="position: relative; z-index: 1;">
                <i class="fas fa-hashtag" style="font-size: 40px; color: #00ff88; margin-bottom: 15px;"></i>
                <h3 style="font-size: 14px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px;">Channels</h3>
                <p style="font-size: 48px; font-weight: 800; margin-top: 10px;"><%= channels %></p>
            </div>
            <div style="position: absolute; bottom: -20px; right: -20px; font-size: 100px; color: rgba(255,255,255,0.03);">
                <i class="fas fa-hashtag"></i>
            </div>
        </div>

        <div class="modern-card" style="position: relative; overflow: hidden;">
            <div style="position: relative; z-index: 1;">
                <i class="fas fa-clock" style="font-size: 40px; color: #00ff88; margin-bottom: 15px;"></i>
                <h3 style="font-size: 14px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px;">Uptime</h3>
                <p style="font-size: 32px; font-weight: 800; margin-top: 10px;">
                    <%= Math.floor(uptime / 86400) %>d <%= Math.floor((uptime % 86400) / 3600) %>h
                </p>
            </div>
            <div style="position: absolute; bottom: -20px; right: -20px; font-size: 100px; color: rgba(255,255,255,0.03);">
                <i class="fas fa-clock"></i>
            </div>
        </div>
    </div>

    <!-- Quick Actions & Info -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 25px;">
        <div class="modern-card">
            <h3 style="font-size: 20px; margin-bottom: 20px;">
                <i class="fas fa-chart-line" style="color: #00ff88; margin-right: 10px;"></i>
                System Status
            </h3>
            <div style="display: grid; gap: 15px;">
                <div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>CPU Usage</span>
                        <span style="color: #00ff88;">32%</span>
                    </div>
                    <div style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                        <div style="width: 32%; height: 100%; background: linear-gradient(90deg, #00ff88, #00ffaa); border-radius: 4px;"></div>
                    </div>
                </div>
                <div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>Memory Usage</span>
                        <span style="color: #00ff88;">256MB / 1GB</span>
                    </div>
                    <div style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                        <div style="width: 25%; height: 100%; background: linear-gradient(90deg, #00ff88, #00ffaa); border-radius: 4px;"></div>
                    </div>
                </div>
                <div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>Commands Loaded</span>
                        <span style="color: #00ff88;"><%= commandsCount %></span>
                    </div>
                    <div style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                        <div style="width: 100%; height: 100%; background: linear-gradient(90deg, #00ff88, #00ffaa); border-radius: 4px;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modern-card">
            <h3 style="font-size: 20px; margin-bottom: 20px;">
                <i class="fas fa-bolt" style="color: #00ff88; margin-right: 10px;"></i>
                Quick Actions
            </h3>
            <div style="display: grid; gap: 10px;">
                <a href="/settings" class="neon-btn" style="text-align: center; text-decoration: none;">
                    <i class="fas fa-cog"></i> Configure Bot
                </a>
                <a href="/commands" class="neon-btn" style="text-align: center; text-decoration: none;">
                    <i class="fas fa-terminal"></i> View Commands
                </a>
                <button class="neon-btn" onclick="location.reload()" style="background: transparent;">
                    <i class="fas fa-sync-alt"></i> Refresh Data
                </button>
            </div>
        </div>
    </div>

    <!-- Bot Info -->
    <div class="modern-card" style="margin-top: 25px;">
        <h3 style="font-size: 20px; margin-bottom: 20px;">
            <i class="fas fa-info-circle" style="color: #00ff88; margin-right: 10px;"></i>
            Bot Information
        </h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
            <div>
                <p style="color: rgba(255,255,255,0.6); margin-bottom: 5px;">Prefix</p>
                <p style="font-size: 24px; font-weight: 600;"><%= config.prefix || '!' %></p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.6); margin-bottom: 5px;">Status</p>
                <p style="font-size: 24px; font-weight: 600; color: #00ff88;"><%= config.status || 'online' %></p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.6); margin-bottom: 5px;">Activity</p>
                <p style="font-size: 24px; font-weight: 600;"><%= config.activity || 'None' %></p>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>